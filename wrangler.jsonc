{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "productbuilding1",
  "compatibility_date": "2026-07-15",
  "main": "worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/*",
      "!/assets/*",
      "!/ads.txt",
      "!/robots.txt",
      "!/sitemap.xml"
    ]
  }
}
